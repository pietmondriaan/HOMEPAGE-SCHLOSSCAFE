---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
---
<Layout
  title="Vermietung & Events | Eismaschine mit Micha | Café mit Herz"
  description="Soft-Eis-Maschine inkl. Eisverkäufer Micha für Ihr Fest — € 500 für 6 Stunden. Kühlwagen-Vermietung auf Anfrage. Schloss-Café Bleiburg."
  canonical="https://www.cafemitherz.at/vermietung/"
>
  <Navbar slot="navbar" />

  <!-- Hero -->
  <section class="relative bg-braun-900 overflow-hidden" aria-labelledby="vermietung-hero-title">
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src="/images/vermietung/eismaschine-micha.jpg"
        alt=""
        width="1200"
        height="800"
        loading="eager"
        class="w-full h-full object-cover object-top opacity-50"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-braun-900/90 via-braun-900/60 to-braun-900/20"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-36">
      <div class="max-w-xl">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-gold" aria-hidden="true">❄</span>
          <span class="font-sans text-gold text-xs tracking-[0.2em] uppercase font-semibold">Events & Vermietung</span>
        </div>
        <h1 id="vermietung-hero-title" class="text-4xl sm:text-6xl font-display text-creme mb-4 leading-tight">
          Eis für Ihr Fest —<br />
          <span class="text-gold italic">mit Micha dabei.</span>
        </h1>
        <p class="text-braun-200 text-base sm:text-lg leading-relaxed mb-8 max-w-md">
          Soft-Eis direkt vom Profi — Micha bringt die Maschine, bedient Ihre Gäste und sorgt für Stimmung.
        </p>
        <a
          href={`https://wa.me/436645336243?text=${encodeURIComponent('Hallo, ich möchte die Eismaschine mit Micha für mein Event buchen.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold inline-flex items-center gap-2"
          aria-label="Eismaschinen-Vermietung per WhatsApp anfragen"
        >
          📱 Jetzt anfragen
        </a>
      </div>
    </div>
  </section>

  <!-- Angebote -->
  <section class="py-16 sm:py-24 bg-creme" aria-labelledby="angebote-title">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="font-sans text-gold tracking-[0.2em] uppercase text-xs sm:text-sm mb-2">Was wir anbieten</p>
        <h2 id="angebote-title" class="text-3xl sm:text-4xl lg:text-5xl font-display text-braun-800">Unsere Angebote</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-10 max-w-4xl mx-auto">

        <!-- Eismaschine mit Micha -->
        <article class="bg-white rounded-2xl shadow-md overflow-hidden">
          <div class="h-52 overflow-hidden">
            <img
              src="/images/vermietung/eismaschine-micha.jpg"
              alt="Micha mit der Soft-Eis-Maschine beim Event"
              width="600"
              height="400"
              loading="lazy"
              class="w-full h-full object-cover object-top"
            />
          </div>
          <div class="p-6 sm:p-8">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="text-xl sm:text-2xl font-display text-braun-800">Soft-Eis-Maschine<br/>mit Eisverkäufer Micha</h3>
              <div class="text-right shrink-0">
                <p class="text-gold font-sans font-bold text-2xl">€ 500</p>
                <p class="text-braun-400 font-sans text-xs">6 Stunden</p>
              </div>
            </div>
            <ul class="text-braun-600 text-sm space-y-1.5 mb-6" role="list">
              <li class="flex items-start gap-2"><span class="text-gold mt-0.5" aria-hidden="true">✓</span>Soft-Eis-Maschine (Soft-Eis, Früchte, Schokolade)</li>
              <li class="flex items-start gap-2"><span class="text-gold mt-0.5" aria-hidden="true">✓</span>Eisverkäufer Micha persönlich dabei</li>
              <li class="flex items-start gap-2"><span class="text-gold mt-0.5" aria-hidden="true">✓</span>Inkl. Material, Auf- & Abbau</li>
              <li class="flex items-start gap-2"><span class="text-gold mt-0.5" aria-hidden="true">✓</span>Geeignet für Hochzeiten, Feste, Firmenevents</li>
            </ul>
            <a
              href={`https://wa.me/436645336243?text=${encodeURIComponent('Hallo, ich möchte die Soft-Eis-Maschine mit Micha für ein Event buchen.')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-gold w-full text-center"
              aria-label="Soft-Eis-Maschine mit Micha per WhatsApp buchen"
            >
              📱 Buchen per WhatsApp
            </a>
          </div>
        </article>

        <!-- Kühlwagen -->
        <article class="bg-white rounded-2xl shadow-md overflow-hidden flex flex-col">
          <div class="h-52 bg-braun-100 flex items-center justify-center">
            <span class="text-7xl" role="img" aria-label="Kühlwagen">🚐❄️</span>
          </div>
          <div class="p-6 sm:p-8 flex-1 flex flex-col">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="text-xl sm:text-2xl font-display text-braun-800">Kühlwagen-<br/>Vermietung</h3>
              <div class="text-right shrink-0">
                <p class="text-braun-500 font-sans text-sm">auf Anfrage</p>
              </div>
            </div>
            <p class="text-braun-600 text-sm leading-relaxed mb-6 flex-1">
              Für größere Events oder Catering-Bedarf: Kühlwagen-Vermietung auf Anfrage. Preise nach Dauer und Anforderung.
            </p>
            <a
              href={`https://wa.me/436645336243?text=${encodeURIComponent('Hallo, ich interessiere mich für die Kühlwagen-Vermietung.')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-braun w-full text-center"
              aria-label="Kühlwagen-Vermietung per WhatsApp anfragen"
            >
              📱 Anfragen
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Kontakt CTA -->
  <section class="py-12 sm:py-16 bg-braun-800" aria-labelledby="vermietung-kontakt-title">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 id="vermietung-kontakt-title" class="text-2xl sm:text-3xl font-display text-creme mb-3">Fragen? Wir sind für Sie da.</h2>
      <p class="text-braun-300 text-sm sm:text-base mb-6">Rufen Sie uns an oder schreiben Sie uns direkt per WhatsApp.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="tel:+4342352979" class="btn-gold inline-flex items-center justify-center gap-2" aria-label="Schloss-Café telefonisch anrufen">
          📞 +43 4235 2979
        </a>
        <a
          href={`https://wa.me/436645336243?text=${encodeURIComponent('Hallo, ich habe eine Frage zur Vermietung.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-braun inline-flex items-center justify-center gap-2 !border-braun-600"
          aria-label="Per WhatsApp kontaktieren"
        >
          📱 WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
