---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

const standorte = [
  {
    id: 'schlosscafe',
    name: 'Schloss-Café',
    ort: 'Bleiburg, Kärnten',
    adresse: '10. Oktober Platz 38, 9150 Bleiburg',
    tel: '+43 4235 2979',
    telHref: 'tel:+4342352979',
    zeiten: 'Täglich 7:00 – 19:00 Uhr',
    beschreibung: 'Im historischen Herz von Bleiburg, direkt neben dem renommierten Werner Berg Museum. Das Schloss-Café vereint kulinarischen Genuss mit Kunst und Kultur. Hausgemachte Torten, Mehlspeisen und Eisspezialitäten täglich frisch. Die Dauerausstellung von Michael Pietrowski — Fadenbilder, Acryl & CrossArt — ist täglich zu sehen und käuflich zu erwerben.',
    bild: '/images/schlosscafe-aussen.jpg',
    bildAlt: 'Schloss-Café Bleiburg Außenansicht',
    maps: 'https://www.google.at/maps/dir//Schloss+Cafe,+10.+Oktober+Pl.+38,+9150+Bleiburg',
    besonderheiten: ['Neben dem Werner Berg Museum', 'Kunstausstellung Pietrowski', 'Tortenvitrine', 'Online-Bestellung möglich'],
    lat: 46.590407,
    lng: 14.794809,
  },
  {
    id: 'reinhart',
    name: 'Café Reinhart',
    ort: 'Eberndorf am Klopeinersee',
    adresse: 'Kreuzbergweg 1, 9141 Eberndorf',
    tel: '+43 4236 2140',
    telHref: 'tel:+4342362140',
    zeiten: 'Täglich 7:00 – 19:00 Uhr',
    beschreibung: 'Am Fuße des Klopeinersees in Eberndorf, Kärnten. Das Café Reinhart lädt in entspannter Atmosphäre zum Verweilen ein — hausgemachte Mehlspeisen, Torten und Eisspezialitäten täglich frisch zubereitet. Ideal nach einem Spaziergang am See oder einem Ausflug in die Südkärntner Region.',
    bild: '/images/cafe-reinhart-aussen.jpg',
    bildAlt: 'Café Reinhart Eberndorf am Klopeinersee',
    maps: 'https://www.google.at/maps/dir//Cafe+Reinhart,+Kreuzberglweg+1,+9141+Eberndorf',
    besonderheiten: ['Direkt am Klopeinersee', 'Entspannte Atmosphäre', 'Hausgemachte Eisspezialitäten', 'Saisonale Spezialitäten'],
    lat: 46.5910418,
    lng: 14.6073595,
  },
]
---
<Layout
  title="Unsere Standorte | Schloss-Café Bleiburg & Café Reinhart Eberndorf"
  description="Schloss-Café Bleiburg (10. Oktober Platz 38) und Café Reinhart Eberndorf am Klopeinersee — beide täglich 7–19 Uhr geöffnet. Hausgemachte Torten und Mehlspeisen."
  canonical="https://www.cafemitherz.at/standort"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "CafeOrCoffeeShop",
        "name": "Schloss-Café",
        "address": { "@type": "PostalAddress", "streetAddress": "10. Oktober Platz 38", "addressLocality": "Bleiburg", "postalCode": "9150", "addressCountry": "AT" },
        "geo": { "@type": "GeoCoordinates", "latitude": 46.590407, "longitude": 14.794809 },
        "telephone": "+4342352979",
        "openingHours": "Mo-Su 07:00-19:00",
        "url": "https://www.cafemitherz.at/standort"
      },
      {
        "@context": "https://schema.org",
        "@type": "CafeOrCoffeeShop",
        "name": "Café Reinhart",
        "address": { "@type": "PostalAddress", "streetAddress": "Kreuzbergweg 1", "addressLocality": "Eberndorf", "postalCode": "9141", "addressCountry": "AT" },
        "geo": { "@type": "GeoCoordinates", "latitude": 46.5910418, "longitude": 14.6073595 },
        "telephone": "+4342362140",
        "openingHours": "Mo-Su 07:00-19:00"
      }
    ])} />
  </Fragment>

  <Navbar slot="navbar" />

  <!-- Header -->
  <section class="bg-braun-900 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-sans text-gold tracking-[0.2em] uppercase text-xs sm:text-sm mb-3">Zwei Cafés, ein Herz</p>
      <h1 class="text-4xl sm:text-6xl font-display text-creme mb-4">Unsere Standorte</h1>
      <p class="text-braun-300 text-sm sm:text-lg max-w-2xl mx-auto leading-relaxed">
        Besuchen Sie uns in Bleiburg oder am Klopeinersee — täglich frisch, täglich herzlich.
      </p>
    </div>
  </section>

  <!-- Standorte -->
  {standorte.map((s, i) => (
    <section
      id={s.id}
      class={`py-16 sm:py-24 ${i % 2 === 0 ? 'bg-creme' : 'bg-braun-50'}`}
      aria-labelledby={`${s.id}-title`}
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class:list={['grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center', i % 2 !== 0 && 'lg:[&>*:first-child]:order-2']}>
          <!-- Bild -->
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src={s.bild}
              alt={s.bildAlt}
              width="800"
              height="600"
              loading={i === 0 ? 'eager' : 'lazy'}
              class="w-full aspect-[4/3] object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-braun-900/40 to-transparent" aria-hidden="true"></div>
          </div>

          <!-- Infos -->
          <div>
            <p class="font-sans text-gold tracking-[0.2em] uppercase text-xs sm:text-sm mb-3">{s.ort}</p>
            <h2 id={`${s.id}-title`} class="text-3xl sm:text-4xl lg:text-5xl font-display text-braun-800 mb-4">{s.name}</h2>
            <p class="text-braun-600 text-sm sm:text-base leading-relaxed mb-6">{s.beschreibung}</p>

            <!-- Öffnungszeiten + Kontakt -->
            <div class="bg-white rounded-xl p-5 sm:p-6 mb-6 space-y-3">
              <div class="flex items-start gap-3">
                <span class="text-gold mt-0.5" aria-hidden="true">🕐</span>
                <div>
                  <p class="font-sans text-braun-700 font-semibold text-sm">Öffnungszeiten</p>
                  <p class="text-braun-600 text-sm">{s.zeiten}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-gold mt-0.5" aria-hidden="true">📍</span>
                <div>
                  <p class="font-sans text-braun-700 font-semibold text-sm">Adresse</p>
                  <address class="not-italic text-braun-600 text-sm">{s.adresse}</address>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-gold mt-0.5" aria-hidden="true">📞</span>
                <div>
                  <p class="font-sans text-braun-700 font-semibold text-sm">Telefon</p>
                  <a href={s.telHref} class="text-gold hover:text-braun-800 transition-colors text-sm">{s.tel}</a>
                </div>
              </div>
            </div>

            <!-- Besonderheiten -->
            <ul class="flex flex-wrap gap-2 mb-6" aria-label={`Besonderheiten ${s.name}`}>
              {s.besonderheiten.map(b => (
                <li class="bg-braun-100 text-braun-700 font-sans text-xs px-3 py-1.5 rounded-full">
                  {b}
                </li>
              ))}
            </ul>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href={s.maps}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-gold text-sm"
                aria-label={`${s.name} auf Google Maps anzeigen`}
              >
                📍 Route berechnen
              </a>
              <a
                href={`https://wa.me/436645336243?text=${encodeURIComponent(`Hallo, ich möchte einen Tisch im ${s.name} reservieren.`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-braun text-sm"
                aria-label={`Tisch im ${s.name} per WhatsApp reservieren`}
              >
                📱 Tisch reservieren
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Verbindendes Element -->
  <section class="py-14 sm:py-20 bg-braun-800 text-center" aria-labelledby="oeffnungszeiten-title">
    <div class="max-w-3xl mx-auto px-4">
      <h2 id="oeffnungszeiten-title" class="text-2xl sm:text-3xl font-display text-creme mb-4">Täglich für Sie da</h2>
      <p class="text-braun-300 text-sm sm:text-base mb-8">
        Beide Cafés sind täglich von 7:00 bis 19:00 Uhr geöffnet — 365 Tage im Jahr.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-braun-700/50 rounded-xl p-6">
          <h3 class="font-display text-creme text-xl mb-2">Schloss-Café Bleiburg</h3>
          <p class="text-gold font-sans text-sm font-semibold mb-1">Mo–So 7:00–19:00</p>
          <a href="tel:+4342352979" class="text-braun-300 font-sans text-sm hover:text-gold transition-colors">+43 4235 2979</a>
        </div>
        <div class="bg-braun-700/50 rounded-xl p-6">
          <h3 class="font-display text-creme text-xl mb-2">Café Reinhart Eberndorf</h3>
          <p class="text-gold font-sans text-sm font-semibold mb-1">Mo–So 7:00–19:00</p>
          <a href="tel:+4342362140" class="text-braun-300 font-sans text-sm hover:text-gold transition-colors">+43 4236 2140</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
