---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

// Events — gefiltert wie in getActiveEvents(), Datum relativ zum Build-Datum
const allEvents = [
  { id: 6, titel: "Ausstellung: Drei Welten im Nahbereich", datum: "2026-11-08", uhrzeit: "noch bis 8. Nov · Di–So 10–18 Uhr", beschreibung: "Mercedes Helnwein, Werner Berg & Alberto Giacometti im Dialog — direkt am 10. Oktober Platz. Zur Eröffnung war Weltkünstler Gottfried Helnwein persönlich in Bleiburg — und zu Gast im Schloss-Café.", bild: "https://www.cafemitherz.at/images/helnwein-besuch.jpg", ort: "Werner Berg Museum · 10. Oktober Platz 4", link: "https://www.wernerberg.museum", dauerausstellung: false, immer_zeigen: true, aktiv: true, istPlakat: true },
  { id: 5, titel: "Neueröffnung nach Umbau", datum: "2026-05-01", uhrzeit: "seit 1. Mai 2026", beschreibung: "Nach einem aufwändigen Umbau erstrahlt das Schloss-Café in neuem Glanz! Frisch renovierte Räume, neue Atmosphäre — aber mit dem gewohnten Herzstück: hausgemachte Mehlspeisen, Torten und Gastfreundschaft.", video: "https://www.cafemitherz.at/videos/neueroffnung-schlosscafe.mp4", bild: null, ort: "Schloss-Café Bleiburg", link: null, dauerausstellung: false, immer_zeigen: true, aktiv: true },
  { id: 4, titel: "Auszahlung Sparverein", datum: "2026-07-05", uhrzeit: "ab 12:00 Uhr", beschreibung: "Die jährliche Auszahlung des Sparvereins ab 12:00 Uhr. Wir freuen uns auf einen gemütlichen Nachmittag im Schloss-Café — mit hausgemachten Mehlspeisen und guter Gesellschaft!", bild: "https://www.cafemitherz.at/images/sparverein-auszahlung.jpg", ort: "Schloss-Café Bleiburg", link: null, dauerausstellung: false, aktiv: true },
  { id: 3, titel: "43. Bleiburger Radwandertag & Sommerfest", datum: "2026-06-20", uhrzeit: "ab 17:00 Uhr", beschreibung: "Der 43. Bleiburger Radwandertag der Kärntner Sparkasse – und wir sind dabei! Das Schloss-Café Bleiburg feiert gleichzeitig sein Sommerfest – kommt vorbei!", bild: "https://www.cafemitherz.at/images/radwandertag-2026-plakat.jpg", ort: "Kärntner Sparkasse Bleiburg, 10. Oktober Platz 38", link: null, dauerausstellung: false, aktiv: true, istPlakat: true },
  { id: 1, titel: "Dauerausstellung: Michael Pietrowski", datum: "2026-01-01", beschreibung: "Fadenbilder, Acryl, CrossArt & Beanie-Serie — Werke können vor Ort besichtigt und erworben werden.", bild: "https://www.cafemitherz.at/images/pietrowski-ausstellung.webp", ort: "Schloss-Café Bleiburg", link: "https://www.pietrowski.at", dauerausstellung: true, aktiv: true },
]

const today = new Date('2026-05-15')
today.setHours(0,0,0,0)
const activeEvents = allEvents
  .filter(e => e.aktiv && (e.dauerausstellung || (e as any).immer_zeigen || new Date(e.datum) >= today))
  .sort((a, b) => {
    if (a.dauerausstellung) return 1
    if (b.dauerausstellung) return -1
    return new Date(a.datum).getTime() - new Date(b.datum).getTime()
  })

// Ticker-Texte
const tickerItems = activeEvents.map(e => `${e.titel} — ${e.ort}`)
---
<Layout
  title="Schloss-Café Bleiburg | Torten, Mehlspeisen & Kunst | Café mit Herz"
  description="Schloss-Café Bleiburg am 10. Oktober Platz – hausgemachte Torten, Mehlspeisen & Eisspezialitäten täglich 7–19 Uhr. Kunst von Pietrowski bis Helnwein. Neben dem Werner Berg Museum."
  canonical="https://www.cafemitherz.at/"
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/hero/hero-eisbecher-frucht.jpg" fetchpriority="high" />
  </Fragment>

  <Navbar slot="navbar" />

  <!-- HERO -->
  <section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden">
    <!-- Hintergrundbild — hell, warm, einladend -->
    <div class="absolute inset-0">
      <img
        src="/images/hero/hero-eisbecher-frucht.jpg"
        alt=""
        width="1920"
        height="1440"
        class="w-full h-full object-cover object-top"
        fetchpriority="high"
        decoding="async"
      />
      <!-- Overlay max 15 % — Bild bleibt sichtbar, Text lesbar via drop-shadow -->
      <div class="absolute inset-0 bg-braun-900/15" aria-hidden="true"></div>
    </div>

    <!-- Restaurant Guru Badge -->
    <a
      href="https://restaurantguru.com"
      target="_blank"
      rel="noopener noreferrer"
      class="absolute top-20 sm:top-24 right-3 sm:right-8 z-20 group flex flex-col items-center gap-1.5"
      aria-label="Restaurant Guru – Best Coffeehouse 2023–2026 (öffnet in neuem Tab)"
    >
      <img
        src="https://www.cafemitherz.at/images/restaurant-guru-2026.webp"
        alt="Restaurant Guru Auszeichnung"
        width="96"
        height="96"
        class="h-16 sm:h-20 lg:h-24 w-auto rounded-lg border border-creme/20 shadow-lg group-hover:border-gold/50 transition-all group-hover:scale-105"
        loading="eager"
      />
      <span class="font-sans text-[8px] sm:text-[9px] bg-creme/15 backdrop-blur-sm text-creme/90 px-2 py-0.5 rounded border border-creme/25 font-semibold tracking-wide whitespace-nowrap">
        Best Coffeehouse 2023 – 2026
      </span>
    </a>

    <!-- Pietrowski-Badge (P2) — dezent, oben links -->
    <a
      href="#events"
      class="absolute top-20 sm:top-24 left-3 sm:left-8 z-20 flex items-center gap-2 bg-braun-900/60 backdrop-blur-sm border border-gold/30 rounded-full px-3 py-1.5 hover:border-gold/70 transition-colors"
      aria-label="Dauerausstellung Michael Pietrowski"
    >
      <span class="text-gold text-xs">🎨</span>
      <span class="font-sans text-[10px] sm:text-xs text-creme/90 leading-tight">Ausstellung<br class="hidden sm:block" /><span class="hidden sm:inline"> Pietrowski</span></span>
    </a>

    <div class="relative z-10 text-center px-5 sm:px-4 max-w-4xl pt-16 sm:pt-0">
      <p class="font-sans text-braun-900 tracking-[0.2em] sm:tracking-[0.3em] uppercase text-xs sm:text-sm mb-3 sm:mb-4 font-semibold [text-shadow:0_1px_3px_rgba(255,255,255,0.8)]">Willkommen bei</p>
      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-display text-braun-900 mb-3 sm:mb-4 leading-tight [text-shadow:0_2px_8px_rgba(255,255,255,0.6)]">
        Café mit Herz
      </h1>
      <p class="text-braun-800 text-lg sm:text-2xl font-light mb-2 sm:mb-3 italic [text-shadow:0_1px_4px_rgba(255,255,255,0.7)]">
        Gastfreundschaft mit ganz viel Herz!
      </p>
      <p class="text-braun-800 text-sm sm:text-base mb-5 sm:mb-6 max-w-2xl mx-auto leading-relaxed [text-shadow:0_1px_3px_rgba(255,255,255,0.7)]">
        Täglich frische Mehlspeisen, Torten & Eisspezialitäten —
        in Bleiburg und Eberndorf am Klopeinersee.
      </p>

      <!-- Öffnungszeiten + Standorte — above the fold -->
      <div class="flex flex-col sm:flex-row gap-2 justify-center mb-5 sm:mb-6">
        <div class="flex items-center gap-2 bg-creme/80 backdrop-blur-sm rounded-full px-4 py-2 border border-braun-300/40">
          <span class="text-braun-700 text-sm" aria-hidden="true">📍</span>
          <span class="font-sans text-xs sm:text-sm text-braun-800 font-medium">Bleiburg · Mo–So 7–19 Uhr</span>
        </div>
        <div class="flex items-center gap-2 bg-creme/80 backdrop-blur-sm rounded-full px-4 py-2 border border-braun-300/40">
          <span class="text-braun-700 text-sm" aria-hidden="true">📍</span>
          <span class="font-sans text-xs sm:text-sm text-braun-800 font-medium">Eberndorf · Mo–So 7–19 Uhr</span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a href="/torten/" class="btn-gold text-base sm:text-lg py-3.5 sm:py-3">
          🛍 Torte bestellen
        </a>
        <a href="#standorte" class="btn-braun text-base sm:text-lg py-3.5 sm:py-3">
          Unsere Cafés entdecken
        </a>
      </div>
    </div>

    <!-- Scroll-Indicator -->
    <div class="absolute bottom-16 sm:bottom-20 left-1/2 -translate-x-1/2 animate-bounce hidden sm:block" aria-hidden="true">
      <div class="w-6 h-10 rounded-full border-2 border-braun-700/50 flex items-start justify-center p-2">
        <div class="w-1.5 h-3 bg-braun-700/70 rounded-full"></div>
      </div>
    </div>

    <!-- EventTicker -->
    {activeEvents.length > 0 && (
      <div class="absolute bottom-0 left-0 right-0 z-20 bg-braun-900/80 backdrop-blur-sm border-t border-braun-700/40 overflow-hidden"
           role="marquee" aria-label="Aktuelle Veranstaltungen">
        <div class="ticker-scroll flex whitespace-nowrap py-2.5">
          {[...tickerItems, ...tickerItems].map((t, i) => (
            <span class="inline-flex items-center gap-3 px-6 font-sans text-xs sm:text-sm text-braun-200">
              <span class="text-gold" aria-hidden="true">★</span>
              {t}
            </span>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- STANDORTE -->
  <section id="standorte" class="py-16 sm:py-24 bg-creme" aria-labelledby="standorte-title">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-16">
        <p class="font-sans text-gold tracking-[0.2em] uppercase text-xs sm:text-sm mb-2 sm:mb-3">Zwei Cafés, ein Herz</p>
        <h2 id="standorte-title" class="text-3xl sm:text-4xl lg:text-5xl font-display text-braun-800">Unsere Standorte</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-10">
        <!-- Schloss-Café — mit Video -->
        <article class="card-hover rounded-2xl overflow-hidden bg-white shadow-md">
          <a href="/standort/" class="block">
            <div class="relative h-48 sm:h-72 overflow-hidden">
              <video
                data-lazy-src="https://www.cafemitherz.at/videos/neueroffnung-schlosscafe.mp4"
                poster="https://www.cafemitherz.at/images/schlosscafe-aussen.jpg"
                muted loop playsinline preload="none"
                class="lazy-video w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                aria-label="Schloss-Café Bleiburg Videovorschau"
              ></video>
              <div class="absolute inset-0 bg-gradient-to-t from-braun-900/60 to-transparent" aria-hidden="true"></div>
              <div class="absolute top-3 left-3 sm:top-4 sm:left-4 bg-gold text-braun-900 font-sans text-[10px] sm:text-xs font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow">
                Neu eröffnet
              </div>
              <div class="absolute top-3 right-3 sm:top-4 sm:right-4 flex items-center gap-1.5 bg-black/40 backdrop-blur-sm text-white font-sans text-[10px] tracking-wide px-2.5 py-1 rounded-full" aria-hidden="true">
                ▶ Live
              </div>
              <!-- Logo overlay -->
              <img
                src="https://www.cafemitherz.at/images/logos/schlosscafe-logo.png"
                alt="Schloss-Café Logo"
                width="100"
                height="28"
                class="absolute bottom-3 left-4 sm:bottom-4 sm:left-6 h-10 sm:h-12 w-auto drop-shadow-lg"
                loading="lazy"
              />
            </div>
            <div class="p-5 sm:p-8">
              <h3 class="text-xl sm:text-2xl font-display text-braun-800 mb-1">Schloss-Café</h3>
              <p class="text-gold font-sans text-sm mb-2 sm:mb-3">10. Oktober Platz 38, 9150 Bleiburg</p>
              <p class="text-braun-600 text-sm sm:text-base leading-relaxed mb-3 sm:mb-4">
                Hausgemachte Torten und Mehlspeisen im historischen Herz von Bleiburg, direkt neben dem Werner Berg Museum. Kunstausstellung von Michael Pietrowski ständig zu sehen.
              </p>
              <div class="flex items-center gap-2 text-gold font-sans text-sm font-semibold">
                Mehr erfahren →
              </div>
            </div>
          </a>
        </article>

        <!-- Café Reinhart — mit Logo -->
        <article class="card-hover rounded-2xl overflow-hidden bg-white shadow-md">
          <a href="/standort/#reinhart" class="block">
            <div class="relative h-48 sm:h-72 overflow-hidden">
              <img
                src="https://www.cafemitherz.at/images/cafe-reinhart-aussen.jpg"
                alt="Café Reinhart Eberndorf am Klopeinersee"
                width="800"
                height="600"
                loading="lazy"
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-braun-900/60 to-transparent" aria-hidden="true"></div>
              <div class="absolute top-3 left-3 sm:top-4 sm:left-4 bg-gold text-braun-900 font-sans text-[10px] sm:text-xs font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow">
                Klopeinersee
              </div>
              <!-- Logo overlay -->
              <img
                src="https://www.cafemitherz.at/images/logos/cafe-reinhart-logo.png"
                alt="Café Reinhart Logo"
                width="100"
                height="28"
                class="absolute bottom-3 left-4 sm:bottom-4 sm:left-6 h-10 sm:h-12 w-auto drop-shadow-lg"
                loading="lazy"
              />
            </div>
            <div class="p-5 sm:p-8">
              <h3 class="text-xl sm:text-2xl font-display text-braun-800 mb-1">Café Reinhart</h3>
              <p class="text-gold font-sans text-sm mb-2 sm:mb-3">Kreuzbergweg 1, 9141 Eberndorf</p>
              <p class="text-braun-600 text-sm sm:text-base leading-relaxed mb-3 sm:mb-4">
                Entspannte Café-Atmosphäre direkt am Klopeinersee in Eberndorf. Hausgemachte Mehlspeisen, Torten und Eisspezialitäten — täglich frisch.
              </p>
              <div class="flex items-center gap-2 text-gold font-sans text-sm font-semibold">
                Mehr erfahren →
              </div>
            </div>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- KLASSIKER -->
  <section class="py-16 sm:py-24 bg-white" aria-labelledby="klassiker-title">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-16">
        <p class="font-sans text-gold tracking-[0.2em] uppercase text-xs sm:text-sm mb-2 sm:mb-3">Café Reinhart & Schloss-Café</p>
        <h2 id="klassiker-title" class="text-3xl sm:text-4xl lg:text-5xl font-display text-braun-800 mb-3 sm:mb-4">Unsere Klassiker</h2>
        <p class="text-braun-500 text-sm sm:text-base max-w-xl mx-auto">
          Täglich frisch in unseren Cafés — die Mehlspeisen, für die man immer wieder kommt.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        {[
          {
            name: 'Erdbeertörtchen',
            beschreibung: 'Hausgemachte Roulade mit Marillen-Marmelade, gesüßtem Schlagobers und frischen Erdbeeren.',
            bild: 'https://www.cafemitherz.at/images/klassiker/erdbeertortchen.jpg',
            video: null,
            badge: null,
          },
          {
            name: 'Schaumrollen',
            beschreibung: 'Hauchdünner Blätterteig, gefüllt mit süßem Ei-Schnee nach Art des Hauses.',
            bild: 'https://www.cafemitherz.at/images/klassiker/schaumrollen.jpg',
            video: 'https://www.cafemitherz.at/images/klassiker/schaumrollen.mp4',
            badge: null,
          },
          {
            name: 'Frühstück',
            beschreibung: 'Üppige Etagère mit Käse, Aufschnitt, Eiern & Lachs — dazu Fruchtspiegel, Joghurt und frische Semmel. Nur auf Vorbestellung.',
            bild: 'https://www.cafemitherz.at/images/klassiker/fruehstueck-1.jpg',
            video: null,
            badge: 'Auf Vorbestellung',
          },
          {
            name: 'Eiskreationen',
            beschreibung: 'Hausgemachte Eisbecher und Eisspezialitäten — täglich frisch, nach Saison und Laune.',
            bild: null,
            video: 'https://www.cafemitherz.at/images/klassiker/eiskreationen.mp4',
            badge: 'Täglich frisch',
          },
        ].map(item => (
          <article class="card-hover bg-creme rounded-2xl overflow-hidden shadow-md">
            <div class="relative h-60 sm:h-64 overflow-hidden">
              {item.video ? (
                <video
                  data-lazy-src={item.video}
                  poster={item.bild ?? undefined}
                  muted loop playsinline preload="none"
                  class="lazy-video w-full h-full object-cover"
                  aria-label={item.name + ' Video'}
                ></video>
              ) : (
                <img
                  src={item.bild}
                  alt={item.name}
                  width="400"
                  height="300"
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
              )}
              {item.video && (
                <div class="absolute top-3 right-3 flex items-center gap-1.5 bg-black/40 backdrop-blur-sm text-white font-sans text-[10px] tracking-wide px-2.5 py-1 rounded-full" aria-hidden="true">
                  ▶ Video
                </div>
              )}
              {item.badge && (
                <div class="absolute top-3 left-3 bg-gold text-braun-900 font-sans text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow">
                  {item.badge}
                </div>
              )}
            </div>
            <div class="p-5 sm:p-6">
              <h3 class="text-xl sm:text-2xl font-display text-braun-800 mb-2">{item.name}</h3>
              <p class="text-braun-500 text-sm leading-relaxed">{item.beschreibung}</p>
              {item.name === 'Frühstück' && (
                <a
                  href={`https://wa.me/436645336243?text=${encodeURIComponent('Hallo, ich möchte ein Frühstück auf Vorbestellung.')}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 btn-gold w-full text-sm"
                  aria-label="Frühstück per WhatsApp vorbestellen"
                >
                  📱 Per WhatsApp vorbestellen
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TORTEN HIGHLIGHT -->
  <section class="py-16 sm:py-24 bg-braun-50" aria-labelledby="torten-title">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-16">
        <p class="font-sans text-gold tracking-[0.2em] uppercase text-xs sm:text-sm mb-2 sm:mb-3">Schlemmen & Genießen</p>
        <h2 id="torten-title" class="text-3xl sm:text-4xl lg:text-5xl font-display text-braun-800 mb-3 sm:mb-4">Unsere Torten</h2>
        <p class="text-braun-500 text-sm sm:text-base max-w-2xl mx-auto">
          Aus hochwertigen, regionalen Zutaten – von unseren Konditormeistern täglich frisch zubereitet.
        </p>
      </div>

      <!-- Torte des Monats -->
      <div class="mb-10 sm:mb-16 bg-gradient-to-r from-gold/20 via-gold/10 to-gold/20 rounded-2xl p-5 sm:p-8 flex flex-col md:flex-row items-center gap-5 sm:gap-8">
        <div class="w-full md:w-1/3 h-44 sm:h-56 rounded-xl overflow-hidden">
          <img
            src="https://www.cafemitherz.at/images/torten/schokosahnetorte-4.jpg"
            alt="Schoko-Sahne-Torte – Torte des Monats Mai 2026"
            width="600"
            height="450"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="flex-1 text-center md:text-left">
          <div class="flex items-center gap-2 mb-2 justify-center md:justify-start">
            <span class="text-gold">⭐</span>
            <span class="font-sans text-gold text-xs sm:text-sm font-semibold tracking-wide uppercase">Torte des Monats Mai 2026</span>
          </div>
          <h3 class="text-2xl sm:text-3xl font-display text-braun-800 mb-2 sm:mb-3">Schoko-Sahne-Torte</h3>
          <p class="text-braun-600 text-sm sm:text-base mb-3 sm:mb-4">
            Saftige Schokoladenschichten mit zarter Sahne — unser Highlight im Mai. Bei Online-Bestellung zum Aktionspreis.
          </p>
          <div class="mb-4 sm:mb-5">
            <span class="text-braun-400 font-sans text-sm line-through mr-2">€ 58,00</span>
            <span class="text-gold font-sans font-bold text-xl">€ 52,00</span>
            <span class="text-braun-500 font-sans text-xs ml-2">bei Online-Bestellung</span>
          </div>
          <a href="/torten/">Jetzt bestellen</a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-8">
        {[
          { name: 'Topfen-Torte', src: 'https://www.cafemitherz.at/images/torten/topfentorte.jpg', text: 'Leicht und erfrischend – mit feinstem Topfen und einem Hauch Zitrone.' },
          { name: 'Schwarzwälder Kirschtorte', src: 'https://www.cafemitherz.at/images/torten/schwarzwaelder.jpg', text: 'Schokolade, Kirschen und Sahne – ein zeitloser Genuss nach traditionellem Rezept.' },
          { name: 'Mokkatorte', src: 'https://www.cafemitherz.at/images/torten/mokkatorte-2.jpg', text: 'Zarter Mokka-Geschmack trifft auf luftige Cremefüllung – für alle, die Kaffee lieben.' },
        ].map(t => (
          <article class="card-hover bg-white rounded-2xl overflow-hidden shadow-md">
            <div class="h-44 sm:h-52 overflow-hidden">
              <img
                src={t.src}
                alt={t.name}
                width="500"
                height="375"
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-5 sm:p-6">
              <h3 class="text-lg sm:text-xl font-display text-braun-800 mb-1.5 sm:mb-2">{t.name}</h3>
              <p class="text-braun-500 text-sm leading-relaxed">{t.text}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center mt-8 sm:mt-12">
        <a href="/torten/" class="btn-braun inline-flex items-center gap-2">
          Alle Torten & Bestellung →
        </a>
      </div>
    </div>
  </section>

  <!-- HELNWEIN KULTUR-MOMENT -->
  <section class="bg-[#0c0906] overflow-hidden" aria-labelledby="kultur-title">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
