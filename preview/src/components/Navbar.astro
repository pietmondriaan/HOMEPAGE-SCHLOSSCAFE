---
const links = [
  { href: '/', label: 'Home' },
  { href: '/torten/', label: 'Torten' },
  { href: '/standort/', label: 'Standorte' },
  { href: '/kontakt/', label: 'Kontakt' },
  { href: '/karten/', label: 'Speisekarten' },
  { href: '/vermietung/', label: 'Vermietung' },
]
const raw = Astro.url.pathname
const current = raw === '/' ? '/' : (raw.endsWith('/') ? raw : raw + '/')
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-braun-900/95 backdrop-blur-md border-b border-braun-700/40" aria-label="Hauptnavigation">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Café mit Herz – Startseite">
        <img
          src="https://www.cafemitherz.at/images/logos/schlosscafe-logo.png"
          alt="Schloss-Café Logo"
          width="120"
          height="33"
          class="h-8 sm:h-9 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {links.map(l => (
          <a
            href={l.href}
            class:list={[
              'font-sans text-sm px-3 py-2 rounded-lg transition-colors',
              current === l.href
                ? 'text-gold font-semibold'
                : 'text-braun-200 hover:text-creme hover:bg-braun-700/40'
            ]}
            aria-current={current === l.href ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))}
        <a href="/torten/" class="btn-gold ml-3 text-sm !py-2 !px-5">
          Torte bestellen
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-braun-200 hover:text-creme p-2"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4" role="menu">
      {links.map(l => (
        <a
          href={l.href}
          class:list={[
            'block font-sans text-sm px-3 py-2.5 rounded-lg mb-1 transition-colors',
            current === l.href
              ? 'text-gold bg-braun-800 font-semibold'
              : 'text-braun-200 hover:text-creme hover:bg-braun-700/40'
          ]}
          role="menuitem"
          aria-current={current === l.href ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))}
      <a href="/torten/" class="btn-gold mt-2 w-full text-sm !py-2.5">
        Torte bestellen
      </a>
    </div>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-16 sm:h-20" aria-hidden="true"></div>

<script>
const btn = document.getElementById('mobile-menu-btn')
const menu = document.getElementById('mobile-menu')
btn?.addEventListener('click', () => {
  const open = menu?.classList.toggle('hidden') === false
  btn.setAttribute('aria-expanded', String(open))
  btn.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen')
})
</script>
