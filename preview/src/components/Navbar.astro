---
const raw = Astro.url.pathname
const current = raw === '/' ? '/' : (raw.endsWith('/') ? raw : raw + '/')
const isActive = (href: string) => current === href

const cafesMenu = [
  { href: '/standort/', label: 'Schloss-Café', sub: 'Bleiburg · 10. Oktober Platz' },
  { href: '/standort/#reinhart', label: 'Café Reinhart', sub: 'Eberndorf · am Klopeinersee' },
  { href: '/karten/', label: 'Speisekarten', sub: 'Getränke & Eisspezialitäten' },
]
const cafesActive = ['/standort/', '/karten/'].some(p => current.startsWith(p))

const flatLinks = [
  { href: '/torten/', label: 'Tortenshop' },
  { href: '/vermietung/', label: 'Vermietung' },
  { href: '/standort/', label: 'Kontakt' },
]
---

<nav class="fixed top-0 w-full z-50 bg-braun-800/95 backdrop-blur-md shadow-lg" aria-label="Hauptnavigation">
  <!-- A11y utility bar -->
  <div class="bg-braun-900 border-b border-braun-800 px-4 sm:px-6 lg:px-8 flex justify-end items-center h-7">
    <button
      id="a11y-toggle"
      class="a11y-bar-btn"
      aria-pressed="false"
      aria-label="Barrierefreie Ansicht aktivieren"
    >
      ♿ Barrierefreie Ansicht
    </button>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">

      <!-- Logos: Schloss-Café + Café Reinhart -->
      <a href="/" class="flex items-center gap-2 sm:gap-3 shrink-0 group" aria-label="Café mit Herz – Startseite">
        <img
          src="/images/logos/schlosscafe-logo.png"
          alt="Schloss-Café"
          width="120"
          height="33"
          class="h-8 sm:h-11 w-auto"
          loading="eager"
        />
        <span class="text-braun-600 font-sans text-sm hidden sm:block" aria-hidden="true">·</span>
        <img
          src="/images/logos/cafe-reinhart-logo.png"
          alt="Café Reinhart"
          width="110"
          height="33"
          class="h-7 sm:h-10 w-auto opacity-90 group-hover:opacity-100 transition-opacity"
          loading="eager"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1 xl:gap-2">

        <!-- Unsere Cafés Dropdown -->
        <div class="relative" id="cafes-dropdown-wrap">
          <button
            id="cafes-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="cafes-menu"
            class:list={[
              'flex items-center gap-1.5 px-3 py-2 rounded-md font-sans text-sm tracking-wide transition-colors',
              cafesActive ? 'text-gold font-semibold' : 'text-braun-200 hover:text-gold-light'
            ]}
          >
            Unsere Cafés
            <svg id="cafes-chevron" width="10" height="10" viewBox="0 0 10 10" fill="currentColor" class="opacity-60 transition-transform duration-200" aria-hidden="true">
              <path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
          </button>

          <div
            id="cafes-menu"
            role="menu"
            class="absolute top-full left-1/2 -translate-x-1/2 mt-1 w-64 opacity-0 scale-y-95 pointer-events-none transition-all duration-200 origin-top"
          >
            <div class="flex justify-center -mb-px">
              <div class="w-3 h-3 bg-braun-700 border-t border-l border-braun-600 rotate-45"></div>
            </div>
            <div class="bg-braun-700 rounded-xl border border-braun-600 shadow-2xl overflow-hidden">
              {cafesMenu.map((item, i) => (
                <a
                  href={item.href}
                  role="menuitem"
                  aria-current={isActive(item.href) ? 'page' : undefined}
                  class:list={[
                    'flex flex-col px-5 py-3.5 transition-colors group',
                    i < cafesMenu.length - 1 ? 'border-b border-braun-600' : '',
                    isActive(item.href) ? 'bg-braun-600/60' : 'hover:bg-braun-600/40'
                  ]}
                >
                  <span class:list={[
                    'font-sans text-sm font-medium transition-colors',
                    isActive(item.href) ? 'text-gold' : 'text-creme group-hover:text-gold-light'
                  ]}>
                    {item.label}
                  </span>
                  <span class="font-sans text-xs text-braun-400 mt-0.5">{item.sub}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Flat Links -->
        {flatLinks.map(l => (
          <a
            href={l.href}
            aria-current={isActive(l.href) ? 'page' : undefined}
            class:list={[
              'px-3 py-2 rounded-md font-sans text-sm tracking-wide transition-colors',
              isActive(l.href) ? 'text-gold font-semibold' : 'text-braun-200 hover:text-gold-light'
            ]}
          >
            {l.label}
          </a>
        ))}

        <!-- Events scroll link -->
        <a href="/#events" class="px-3 py-2 rounded-md font-sans text-sm tracking-wide text-braun-200 hover:text-gold-light transition-colors">
          Events
        </a>

        <!-- Social -->
        <div class="flex items-center gap-2 ml-1 pl-3 border-l border-braun-600">
          <a href="https://www.facebook.com/search/top?q=schloss%20quadrat" target="_blank" rel="noopener noreferrer"
             class="w-7 h-7 rounded-full flex items-center justify-center text-braun-400 hover:text-gold hover:bg-braun-700 transition-colors"
             aria-label="Facebook">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        </div>

        <!-- CTA -->
        <a href="/torten/" class="btn-gold text-sm !py-2 !px-5 ml-1 shrink-0">
          Torte bestellen
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-btn"
        class="lg:hidden text-creme p-2 -mr-2 min-w-[44px] min-h-[44px] flex items-center justify-center"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-bars" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true" class="hidden">
          <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 top-[92px] sm:top-[108px] z-40 bg-braun-800 translate-x-full transition-transform duration-300 ease-out overflow-y-auto"
  aria-hidden="true"
>
  <div class="flex flex-col min-h-full">
    <div class="flex-1 py-4">

      <!-- Unsere Cafés accordion -->
      <div>
        <button id="mobile-cafes-btn"
          class="w-full flex items-center justify-between px-6 py-4 font-sans text-base text-braun-200 active:bg-braun-700"
        >
          <span class:list={[cafesActive && 'text-gold font-semibold']}>Unsere Cafés</span>
          <svg id="mobile-cafes-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" class="text-braun-400 transition-transform duration-200" aria-hidden="true">
            <path stroke-linecap="round" d="M2 4l4 4 4-4"/>
          </svg>
        </button>
        <div id="mobile-cafes-panel" class="overflow-hidden max-h-0 transition-all duration-300">
          {cafesMenu.map(item => (
            <a href={item.href} class:list={[
              'flex flex-col pl-10 pr-6 py-3 border-l-2 mx-6 mb-1 rounded-r-lg transition-colors',
              isActive(item.href)
                ? 'border-gold bg-braun-700/50'
                : 'border-braun-600 hover:border-gold-light hover:bg-braun-700/30'
            ]}>
              <span class:list={['font-sans text-sm font-medium', isActive(item.href) ? 'text-gold' : 'text-braun-200']}>
                {item.label}
              </span>
              <span class="text-xs text-braun-500 mt-0.5">{item.sub}</span>
            </a>
          ))}
        </div>
      </div>

      {flatLinks.map(l => (
        <a href={l.href} class:list={[
          'block px-6 py-4 font-sans text-base active:bg-braun-700 transition-colors',
          isActive(l.href) ? 'text-gold bg-braun-700/50 font-semibold' : 'text-braun-200'
        ]}>
          {l.label}
        </a>
      ))}
      <a href="/#events" class="block px-6 py-4 font-sans text-base text-braun-200 active:bg-braun-700 transition-colors">
        Events
      </a>
    </div>

    <!-- Mobile Footer -->
    <div class="p-6 border-t border-braun-700 space-y-3">
      <a href="tel:+4342352979"
        class="flex items-center justify-center gap-2.5 w-full py-3.5 rounded-xl bg-braun-700 border border-braun-600 text-creme font-sans text-sm font-medium active:bg-braun-600 transition-colors">
        📞 04235 2979 anrufen
      </a>
      <a href="/torten/" class="btn-gold text-base text-center block py-4 w-full">
        Torte bestellen
      </a>
    </div>
  </div>
</div>

<!-- Spacer: navbar h-16/h-20 + a11y bar h-7 (28px) -->
<div class="h-[92px] sm:h-[108px]" aria-hidden="true"></div>

<script>
// A11y toggle
const a11yBtn = document.getElementById('a11y-toggle')
function setAccessible(on: boolean) {
  const html = document.documentElement
  if (on) {
    html.setAttribute('data-accessible', '')
    a11yBtn?.setAttribute('aria-pressed', 'true')
    a11yBtn?.setAttribute('aria-label', 'Barrierefreie Ansicht deaktivieren')
  } else {
    html.removeAttribute('data-accessible')
    a11yBtn?.setAttribute('aria-pressed', 'false')
    a11yBtn?.setAttribute('aria-label', 'Barrierefreie Ansicht aktivieren')
  }
  try { localStorage.setItem('a11y', on ? '1' : '0') } catch {}
}
// Sync button state with current html attribute (set by early inline script)
if (document.documentElement.hasAttribute('data-accessible')) {
  a11yBtn?.setAttribute('aria-pressed', 'true')
  a11yBtn?.setAttribute('aria-label', 'Barrierefreie Ansicht deaktivieren')
}
a11yBtn?.addEventListener('click', () => {
  setAccessible(!document.documentElement.hasAttribute('data-accessible'))
})

// Dropdown
const btn = document.getElementById('cafes-btn')
const menu = document.getElementById('cafes-menu')
const chevron = document.getElementById('cafes-chevron')
const wrap = document.getElementById('cafes-dropdown-wrap')
let closeTimer: ReturnType<typeof setTimeout>

function openDropdown() {
  clearTimeout(closeTimer)
  menu?.classList.remove('opacity-0', 'scale-y-95', 'pointer-events-none')
  menu?.classList.add('opacity-100', 'scale-y-100', 'pointer-events-auto')
  btn?.setAttribute('aria-expanded', 'true')
  chevron?.classList.add('rotate-180')
}
function closeDropdown() {
  closeTimer = setTimeout(() => {
    menu?.classList.add('opacity-0', 'scale-y-95', 'pointer-events-none')
    menu?.classList.remove('opacity-100', 'scale-y-100', 'pointer-events-auto')
    btn?.setAttribute('aria-expanded', 'false')
    chevron?.classList.remove('rotate-180')
  }, 150)
}

wrap?.addEventListener('mouseenter', openDropdown)
wrap?.addEventListener('mouseleave', closeDropdown)
btn?.addEventListener('click', () => {
  const open = btn.getAttribute('aria-expanded') === 'true'
  open ? closeDropdown() : openDropdown()
})
document.addEventListener('mousedown', (e) => {
  if (!wrap?.contains(e.target as Node)) closeDropdown()
})

// Mobile menu
const mobileBtn = document.getElementById('mobile-btn')
const mobileMenu = document.getElementById('mobile-menu')
const iconBars = document.getElementById('icon-bars')
const iconClose = document.getElementById('icon-close')

mobileBtn?.addEventListener('click', () => {
  const open = mobileMenu?.classList.toggle('translate-x-full') === false
  mobileMenu?.setAttribute('aria-hidden', String(!open))
  mobileBtn.setAttribute('aria-expanded', String(open))
  mobileBtn.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen')
  iconBars?.classList.toggle('hidden', open)
  iconClose?.classList.toggle('hidden', !open)
  document.body.style.overflow = open ? 'hidden' : ''
})

// Mobile Cafés accordion
const mobileCafesBtn = document.getElementById('mobile-cafes-btn')
const mobileCafesPanel = document.getElementById('mobile-cafes-panel')
const mobileCafesChevron = document.getElementById('mobile-cafes-chevron')
mobileCafesBtn?.addEventListener('click', () => {
  const isOpen = mobileCafesPanel?.style.maxHeight && mobileCafesPanel.style.maxHeight !== '0px'
  if (isOpen) {
    mobileCafesPanel!.style.maxHeight = '0px'
    mobileCafesChevron?.classList.remove('rotate-180')
  } else {
    mobileCafesPanel!.style.maxHeight = mobileCafesPanel!.scrollHeight + 'px'
    mobileCafesChevron?.classList.add('rotate-180')
  }
})
</script>
